---
import type {SerializedEditorState} from "lexical";
import {convertLexicalToHTML} from '@payloadcms/richtext-lexical/html'
import {getPosts, postToPath, postToPublishDate} from "@lib/postUtils";
import {getMainImage, getThubmnailAndAuthorImages, imagePathToUrl} from "@lib/mediaUtils";
import Layout from '@layouts/Layout.astro';
import type {Post} from "@root/payload-types";
import MediaImage from "@components/MediaImage.astro";
import SinglePost from "@components/SinglePost.astro";


export async function getStaticPaths() {
    const parseImages = async (posts: Post[]) => {
        return Promise.all(posts.map(async (post) => {
            if (!post.subcontent) {
                return
            }
            await Promise.all(post.subcontent?.root.children.map(async (node: any) => {
                if (node.type === 'upload') {
                    const thisImage = await imagePathToUrl({
                        path: node.value.url,
                        alt: node.value.alt,
                        height: node.value.height,
                        width: node.value.width
                    })
                    node.value.url = thisImage.src
                }
            }))
        }));
    }

    const posts = await getPosts()
    await parseImages(posts)

    return posts.map((post) => {
        return {
            params: {path: postToPath(post)},
            props: {post},
        };
    });
}

const {post} = Astro.props;

---
<SinglePost post={post} />