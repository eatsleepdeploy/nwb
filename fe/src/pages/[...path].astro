---
import {getPosts, postToPath} from "@lib/postUtils";
import {imagePathToUrl} from "@lib/mediaUtils";
import type {Post} from "@root/payload-types";
import SinglePost from "@components/SinglePost.astro";


export async function getStaticPaths() {
    const parseImages = async (posts: Post[]) => {
        return Promise.all(posts.map(async (post) => {
            if (!post.subcontent) {
                return
            }
            await Promise.all(post.subcontent?.root.children.map(async (node: any) => {
                if (node.type === 'upload') {
                    const thisImage = await imagePathToUrl({
                        path: node.value.url,
                        alt: node.value.alt,
                        height: node.value.height,
                        width: node.value.width
                    })
                    node.value.url = thisImage.src
                }
            }))
        }));
    }

    const posts = await getPosts(Number.MAX_SAFE_INTEGER)
    await parseImages(posts)
    // let previousPost: Post | null = null;
    return posts.map((post, i) => {
        // const thisPreviousPost = previousPost;
        const previousPost = i > 0 ? posts[i - 1] : null;
        const nextPost = i < posts.length - 1 ? posts[i + 1] : null;
        return {
            params: {path: postToPath(post)},
            props: {
                nextPost: previousPost,
                post,
                previousPost: nextPost,}
        };
    });
}

const {nextPost, post, previousPost} = Astro.props;

---
<SinglePost nextPost={nextPost} post={post} previousPost={previousPost} />