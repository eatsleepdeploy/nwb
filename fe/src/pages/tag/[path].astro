---
import Layout from '@layouts/Layout.astro';
import {postToPath, getPostsWithTags} from "@lib/postUtils";
import {getTags} from "@lib/tagUtils";
import {Post, Tag} from "@root/payload-types";
import {getImagesForPosts} from "@lib/mediaUtils";
import MediaImage from "@components/MediaImage.astro";


export async function getStaticPaths() {
    const tags = await getTags()
    return tags.map((tag: Tag) => {
        console.log(`/tag/${tag.slug}`)
        return {
            params: {path: tag.slug},
            props: {tag},
        };
    });
}


const {tag} = Astro.props;
const posts = await getPostsWithTags([tag.slug])
const {imagesByAuthorId, imagesByPostId} = await getImagesForPosts(posts)
---

<Layout title="Home">
  <div hidden={posts.length == 0} class="px-10 my-12 bounded bg-white">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-2">
      <div class="flex items-end my-8 mb-16 border-spacing-0 md:col-span-2 justify-center ">
        <h3 class="max-h-full size-override text-white text-[1.8em] uppercase bg-black px-4 py-2 ">
          <span class="">Tag: {tag.title}</span>
        </h3>
      </div>
        {
            posts.map((post: Post, i: number) => (
                <a href={postToPath(post)} class="flex flex-col gap-3 md:flex-row align-middle">
                    <MediaImage image={imagesByPostId.get(post.id)?.image} class="max-w-full md:max-w-1/2 h-max" />
                    <div class="flex flex-col flex-1 overflow-hidden justify-start">
                      <h3 class="size-override text-[1.6em] md:text-[1.8em] lg:text-[2.5em] break-words">{post.title}</h3>
                      <p class="text-sm mt-1 mb-0">{post.excerpt}</p>
                        {post.author &&
                            <p class="text-sm mt-1 font-bold">
                              <MediaImage class="inline-block rounded-full mr-2"
                                          image={imagesByAuthorId.get(post.author.id)?.image}
                                          style={{width: '20px', height: '20px'}}/>
                                {post.author?.name}</p>}
                    </div>
                  </a>
            ))
        }
    </div>
  </div>
  <div>FOOTER</div>

</Layout>